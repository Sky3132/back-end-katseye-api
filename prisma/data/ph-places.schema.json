{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PH Places Seed",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "type", "parent_id", "country_code", "name"],
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "type": { "type": "string", "enum": ["country", "region", "province", "city", "district"] },
      "parent_id": { "type": "string" },
      "country_code": { "type": "string", "enum": ["PH"] },
      "name": { "type": "string", "minLength": 1 },
      "code": { "type": ["string", "null"] },
      "has_children": { "type": ["boolean", "number", "null"] },
      "sort_order": { "type": ["number", "null"] }
    }
  }
}

