generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  user
  admin
}

enum PlaceType {
  country
  region
  province
  city
  district
}

model admin {
  admin_id Int    @id @default(autoincrement())
  username String @unique @db.VarChar(100)
  password String @db.VarChar(255)
  role     UserRole @default(admin)

  products       product[]
  inventory_logs inventory_log[]
}

model user {
  user_id  Int    @id @default(autoincrement())
  name     String @db.VarChar(150)
  email    String @unique @db.VarChar(150)
  password String @db.VarChar(255)
  role     UserRole @default(user)

  carts     cart[]
  orders    order[]
  addresses address[]
  details   user_details?
}

model user_details {
  user_details_id Int      @id @default(autoincrement())
  user_id         Int      @unique
  full_name       String?  @db.VarChar(150)
  phone_e164      String?  @db.VarChar(32)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user user @relation(fields: [user_id], references: [user_id], onDelete: Cascade, map: "user_details_user_id_fkey")

  @@index([user_id], map: "user_details_user_id_idx")
}

model address {
  address_id Int    @id @default(autoincrement())
  user_id    Int
  is_default Boolean @default(false)
  full_name  String? @db.VarChar(150)
  email      String? @db.VarChar(150)
  phone_e164 String? @db.VarChar(32)
  region     String? @db.VarChar(100)
  street     String @db.VarChar(255)
  city       String @db.VarChar(100)
  province   String @db.VarChar(100)
  barangay   String? @db.VarChar(100)
  zip_code   String @db.VarChar(20)
  country    String @db.VarChar(100)
  country_code String? @db.VarChar(2)

  region_id   String? @db.VarChar(64)
  province_id String? @db.VarChar(64)
  city_id     String? @db.VarChar(64)
  district_id String? @db.VarChar(64)

  user   user    @relation(fields: [user_id], references: [user_id], onDelete: Cascade, map: "address_user_id_fkey")
  orders order[]

  @@index([user_id], map: "address_user_id_idx")
  @@index([user_id, is_default])
  @@index([country_code])
}

model cart {
  cart_id Int @id @default(autoincrement())
  user_id Int

  user       user        @relation(fields: [user_id], references: [user_id], onDelete: Cascade, map: "cart_user_id_fkey")
  cart_items cart_item[]

  @@unique([user_id])
}

model cart_item {
  cart_item_id Int @id @default(autoincrement())
  cart_id      Int
  product_id   Int
  quantity     Int @default(1)

  cart    cart    @relation(fields: [cart_id], references: [cart_id], onDelete: Cascade, map: "cart_item_cart_id_fkey")
  product product @relation(fields: [product_id], references: [product_id], map: "cart_item_product_id_fkey")

  @@index([cart_id], map: "cart_item_cart_id_idx")
  @@index([product_id], map: "cart_item_product_id_idx")
}

model category {
  category_id   Int    @id @default(autoincrement())
  category_name String @db.VarChar(100)

  parent_category_id Int?
  parent             category?  @relation("category_parent", fields: [parent_category_id], references: [category_id])
  children           category[] @relation("category_parent")

  products product[]

  @@index([parent_category_id])
}

model product {
  product_id   Int     @id @default(autoincrement())
  product_name String  @db.VarChar(150)
  title        String? @db.VarChar(150)
  description  String? @db.VarChar(1000)
  imgsrc       String? @db.VarChar(1000)
  image_url    String? @db.VarChar(1000)
  images       String? @db.LongText
  price        Decimal @db.Decimal(10, 2)
  stock        Int     @default(0)

  archived_at DateTime?

  admin_id    Int
  category_id Int?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  admin    admin     @relation(fields: [admin_id], references: [admin_id], map: "product_admin_id_fkey")
  category category? @relation(fields: [category_id], references: [category_id], map: "product_category_id_fkey")

  variants       product_variant[]
  cart_items     cart_item[]
  order_items    order_item[]
  inventory_logs inventory_log[] // ADD THIS

  @@index([admin_id], map: "product_admin_id_fkey")
  @@index([category_id], map: "product_category_id_fkey")
}

model inventory_log {
  inventory_id Int      @id @default(autoincrement())
  product_id   Int
  admin_id     Int
  change_qty   Int
  action       String   @db.VarChar(50)
  created_at   DateTime @default(now())

  product product @relation(fields: [product_id], references: [product_id], onDelete: Cascade, map: "inventory_log_product_id_fkey")
  admin   admin   @relation(fields: [admin_id], references: [admin_id], map: "inventory_log_admin_id_fkey")

  @@index([product_id], map: "inventory_log_product_id_idx")
  @@index([admin_id], map: "inventory_log_admin_id_idx")
}

model product_variant {    
  variant_id Int      @id @default(autoincrement())
  product_id Int
  name       String   @db.VarChar(150)
  sku        String?  @db.VarChar(120)
  price      Decimal? @db.Decimal(10, 2)
  stock      Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product product @relation(fields: [product_id], references: [product_id], onDelete: Cascade, map: "product_variant_product_id_fkey")

  @@index([product_id])
}

model order {
  order_id       Int      @id @default(autoincrement())
  user_id        Int
  address_id     Int
  order_date     DateTime @default(now())
  payment_method String   @db.VarChar(100)
  currency       String   @default("USD") @db.VarChar(3)
  subtotal_amount Decimal @default(0) @db.Decimal(10, 2)
  shipping_fee    Decimal @default(0) @db.Decimal(10, 2)
  tax_amount     Decimal  @default(0) @db.Decimal(10, 2)
  usd_to_php_rate Float?
  display_currency String? @db.VarChar(3)
  fx_rate_usd      Float?
  fx_rate_usd_to_display Float?
  approx_total_display Float?
  total_amount   Decimal  @db.Decimal(10, 2)
  status         String   @default("pending")

  customer_name  String? @db.VarChar(150)
  customer_email String? @db.VarChar(150)
  customer_phone String? @db.VarChar(32)

  address_street   String? @db.VarChar(255)
  address_zip_code String? @db.VarChar(20)
  country_code     String? @db.VarChar(2)
  country_name     String? @db.VarChar(100)
  region_name      String? @db.VarChar(100)
  province_name    String? @db.VarChar(100)
  city_name        String? @db.VarChar(100)
  district_name    String? @db.VarChar(100)

  region_id   String? @db.VarChar(64)
  province_id String? @db.VarChar(64)
  city_id     String? @db.VarChar(64)
  district_id String? @db.VarChar(64)

  user        user         @relation(fields: [user_id], references: [user_id], onDelete: Cascade, map: "order_user_id_fkey")
  address     address      @relation(fields: [address_id], references: [address_id], map: "order_address_id_fkey")
  order_items order_item[]
  shipment    shipment? // ADD THIS

  @@index([user_id], map: "order_user_id_idx")
  @@index([address_id], map: "order_address_id_idx")
  @@index([customer_email])
}

model place {
  id           String    @id @db.VarChar(64)
  type         PlaceType
  parent_id    String?   @db.VarChar(64)
  country_code String    @db.VarChar(2)
  name         String    @db.VarChar(255)
  code         String?   @db.VarChar(64)
  has_children Boolean   @default(false)
  sort_order   Int       @default(0)

  parent   place?   @relation("place_parent", fields: [parent_id], references: [id], onDelete: SetNull)
  children place[]  @relation("place_parent")

  @@index([type, parent_id])
  @@index([country_code, type])
  @@index([country_code, name])
}

model location_schema {
  country_code String @id @db.VarChar(2)
  levels       Json
}

model calling_code {
  country_code String  @id @db.VarChar(2)
  calling_code String  @db.VarChar(8)
  country_name String? @db.VarChar(100)
  flag_emoji   String? @db.VarChar(16)
}

model order_item {
  order_item_id Int     @id @default(autoincrement())
  order_id      Int
  product_id    Int
  quantity      Int
  subtotal      Decimal @db.Decimal(10, 2)

  order   order   @relation(fields: [order_id], references: [order_id], onDelete: Cascade, map: "order_item_order_id_fkey")
  product product @relation(fields: [product_id], references: [product_id], map: "order_item_product_id_fkey")

  @@index([order_id], map: "order_item_order_id_idx")
  @@index([product_id], map: "order_item_product_id_idx")
}

model notification {
  notification_id Int      @id @default(autoincrement())
  title           String   @db.VarChar(255)
  details         String   @db.VarChar(1000)
  time            DateTime
  created_at      DateTime @default(now())
}

model shipment {
  shipment_id     Int     @id @default(autoincrement())
  order_id        Int     @unique
  courier         String  @db.VarChar(100)
  tracking_number String? @db.VarChar(150)
  shipping_fee    Decimal @db.Decimal(10, 2)

  status       String    @default("processing")
  shipped_at   DateTime?
  delivered_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  order order @relation(fields: [order_id], references: [order_id], onDelete: Cascade, map: "shipment_order_id_fkey")
  parcel_tracking parcel_tracking?

  @@index([order_id], map: "shipment_order_id_idx")
}

model parcel_tracking {
  parcel_tracking_id Int      @id @default(autoincrement())
  order_id           Int      @unique
  token              String   @unique @db.VarChar(80)

  customer_email     String   @db.VarChar(150)
  destination_address String  @db.VarChar(500)
  destination_lat    Decimal? @db.Decimal(10, 7)
  destination_lng    Decimal? @db.Decimal(10, 7)
  eta_date           DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  shipment shipment @relation(fields: [order_id], references: [order_id], onDelete: Cascade, map: "parcel_tracking_order_id_fkey")

  @@index([order_id], map: "parcel_tracking_order_id_idx")
  @@index([token], map: "parcel_tracking_token_idx")
}
